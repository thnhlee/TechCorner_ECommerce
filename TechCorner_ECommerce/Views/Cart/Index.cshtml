@model IEnumerable<TechCorner_ECommerce.ViewModels.CartItemVM>
@{
	ViewData["Title"] = "Cart";
}
<script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.6.0/jquery.min.js"></script>
<link href="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.css" rel="stylesheet"/>
<script src="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.js"></script>  
<div class="hero-wrap hero-bread" style="background-image: url('images/bg_6.jpg');">
    <div class="container">
    <div class="row no-gutters slider-text align-items-center justify-content-center">
        <div class="col-md-9 ftco-animate text-center">
        <p class="breadcrumbs"><span class="mr-2"><a href="index.html">Home</a></span> <span>Cart</span></p>
        <h1 class="mb-0 bread">My Wishlist</h1>
        </div>
    </div>
    </div>
</div>

<section class="ftco-section ftco-cart">
    <div class="container" style="max-width: 1500px;"> 
        <div class="row cart-wrapper">

            <!--PRODUCT TABLE-->
            <div class="col-lg-9 ftco-animate d-flex">
                <div class="cart-list w-100">
                    <table class="table">
                        <thead class="thead-primary">
                            <tr class="text-center">
                                <th>&nbsp;</th>
                                <th>&nbsp;</th>
                                <th>Product</th>
                                <th>Price</th>
                                <th>Quantity</th>
                                <th>Total</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model)
                            {
                                <tr class="text-center">
                                    <td class="product-remove">
                                        <a href="#" class="js-remove-cart" data-id="@item.ProductVariantId">
                                            <span class="ion-ios-close"></span>
                                        </a>
                                    </td>

                                    <td class="image-prod">
                                        <div class="img" style="background-image:url(images/product-3.jpg);"></div>
                                    </td>

                                    <td class="product-name">
                                        <h3>@item.ProductName</h3>
                                    </td>

                                    <td class="price">$@item.Price</td>

                                    <td class="quantity">
                                        <div class="input-group mb-3">
                                            <div class="input-group js-cart-qty cart-qty-group">

                                                <div class="input-group-prepend">
                                                    <button type="button"
                                                            class="qty-minus btn btn-sm btn-outline-secondary"
                                                            data-id="@item.ProductVariantId">−</button>
                                                </div>

                                                <input type="text"
                                                       class="quantity form-control form-control-sm text-center"
                                                       value="@item.Quantity"
                                                       readonly />

                                                <div class="input-group-append">
                                                    <button type="button"
                                                            class="qty-plus btn btn-sm btn-outline-secondary"
                                                            data-id="@item.ProductVariantId">+</button>
                                                </div>

                                            </div>
                                        </div>
                                    </td>

                                    <td class="total">$@item.SubTotal</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>

            <!--CART TOTAL-->
            <div class="col-lg-3 cart-wrap ftco-animate">
               
                    <div class="cart-total  w-100">
                        <h3>Cart Totals</h3>

                        <p class="d-flex">
                            <span>Subtotal</span>
                            <span id="cart-subtotal" data-value="@Model.Sum(p => p.SubTotal)">
                                $@Model.Sum(p => p.SubTotal)
                            </span>
                        </p>

                        <p class="d-flex">
                            <span>Delivery</span>
                            <span>0.00</span>
                        </p>


                        <hr>

                        <p class="d-flex total-price">
                            <span>Total</span>
                            <span>$17.60</span>
                        </p>

                        <a href="checkout.html" class="btn btn-primary py-1 px-2 mt-auto">
                            Proceed to Checkout
                        </a>
                    </div>
                

            </div>

        </div>
    </div>
</section>


<script>
document.addEventListener("click", function (e) {

    const cartQtyEl = document.getElementById("cart-qty");

    // ================= FORMAT SUBTOTAL =================
    function updateSubtotal(data) {
        const subtotalEl = document.getElementById("cart-subtotal");
        if (!subtotalEl || !data) return;

        const total = data.totalPrice ?? data.subTotal;
        if (total === undefined || total === null) return;

        subtotalEl.innerText = "$" + Number(total).toLocaleString("en-US", {
            minimumFractionDigits: 0,
            maximumFractionDigits: 2
        });
    }

    // ================= UPDATE CART =================
    function updateCart(variantId, qty, input, row) {

        fetch(`/Cart/UpdateQuantity?variantId=${variantId}&quantity=${qty}`)
            .then(res => res.json())
            .then(data => {

                if (!data.success) return;

                // update input
                if (input) input.value = qty;

                // update row total
                if (row) {
                    const priceText = row.querySelector(".price")?.innerText || "0";
                    const price = parseFloat(priceText.replace("$", "")) || 0;

                    const totalCell = row.querySelector(".total");

                    if (totalCell) {
                        const newTotal = price * qty;

                        totalCell.innerText = "$" + newTotal.toLocaleString("en-US", {
                            minimumFractionDigits: 0,
                            maximumFractionDigits: 2
                        });
                    }
                }

                // update cart quantity
                if (cartQtyEl) cartQtyEl.innerText = data.quantity;

                // update subtotal
                updateSubtotal(data);

                toastr.success("Cart Updated!!");
            });
    }

    // ================= REMOVE ITEM =================
    const removeBtn = e.target.closest(".js-remove-cart");
    if (removeBtn) {
        e.preventDefault();

        const variantId = removeBtn.dataset.id;
        const row = removeBtn.closest("tr");

        fetch(`/Cart/RemoveCart?variantId=${variantId}`)
            .then(res => res.json())
            .then(data => {

                if (!data.success) return;

                row?.remove();

                // nếu rỗng cart
                if (document.querySelectorAll("tbody tr").length === 0) {
                    location.reload();
                    return;
                }

                if (cartQtyEl) cartQtyEl.innerText = data.quantity;

                // tính lại subtotal từ DOM
                let subtotal = 0;

                document.querySelectorAll(".total").forEach(el => {
                    const val = parseFloat(el.innerText.replace("$", "")) || 0;
                    subtotal += val;
                });

                const subtotalEl = document.getElementById("cart-subtotal");
                if (subtotalEl) {
                    subtotalEl.innerText = "$" + subtotal.toLocaleString("en-US");
                }

                toastr.success("Item Deleted");
            });

        return;
    }

    // ================= PLUS =================
    const plusBtn = e.target.closest(".qty-plus");
    if (plusBtn) {

        const variantId = plusBtn.dataset.id;

        const wrapper = plusBtn.closest(".js-cart-qty");
        const input = wrapper?.querySelector("input");
        const row = plusBtn.closest("tr");

        let qty = parseInt(input?.value || "1") + 1;

        updateCart(variantId, qty, input, row);
        return;
    }

    // ================= MINUS =================
    const minusBtn = e.target.closest(".qty-minus");
    if (minusBtn) {

        const variantId = minusBtn.dataset.id;

        const row = minusBtn.closest("tr");
        const input = row?.querySelector("input");

        let qty = parseInt(input?.value || "1");

        // nếu <= 1 thì remove luôn
        if (qty <= 1) {
            fetch(`/Cart/RemoveCart?variantId=${variantId}`)
                .then(res => res.json())
                .then(data => {

                    if (!data.success) return;

                    row?.remove();

                    if (document.querySelectorAll("tbody tr").length === 0) {
                        location.reload();
                        return;
                    }

                    if (cartQtyEl) cartQtyEl.innerText = data.quantity;

                    let subtotal = 0;

                    document.querySelectorAll(".total").forEach(el => {
                        const val = parseFloat(el.innerText.replace("$", "")) || 0;
                        subtotal += val;
                    });

                    document.getElementById("cart-subtotal").innerText =
                        "$" + subtotal.toLocaleString("en-US");

                    updateSubtotal(data);

                    toastr.success("Item Deleted");
                });

            return;
        }

        qty--;
        updateCart(variantId, qty, input, row);
        return;
    }

});


// ================= TOAST CONFIG =================
toastr.options = {
    closeButton: true,
    progressBar: true,
    positionClass: "toast-top-right",
    timeOut: "300"
};
</script>






