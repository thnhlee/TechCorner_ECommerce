@section Scripts {
@* Add or decrease items *@
<script>
    $(document).on('click', '.qty-plus', function (e) {
        e.preventDefault();

        let input = $(this)
            .closest('.input-group')
            .find('.quantity');

        let qty = parseInt(input.val()) || 1;

        input.val(qty + 1);
    });

    $(document).on('click', '.qty-minus', function (e) {
        e.preventDefault();

        let input = $(this)
            .closest('.input-group')
            .find('.quantity');

        let qty = parseInt(input.val()) || 1;

        if (qty > 1) input.val(qty - 1);
    });
</script>

@* Add to cart *@
<script>
    document.addEventListener("click", function (e) {
        const btn = e.target.closest(".btn-black");
            if (!btn) return;
            e.preventDefault(); 

            const id = btn.dataset.id;
            const qtyInput = document.querySelector(".quantity");
            const qty = qtyInput ? qtyInput.value : 1;

            fetch(`/Cart/AddToCart?id=${id}&quantity=${qty}`, {
                method: 'GET'
            })
            .then(res => res.json())
            .then(data => {
                if (data.success) {
                    toastr.success("Đã thêm vào giỏ hàng!");

                    const cartQty = document.getElementById("cart-qty");
                    if (cartQty) {
                        cartQty.innerText = data.quantity;
                    }

                } else {
                    toastr.error("Có lỗi xảy ra!");
                }
            });

        });
    

    toastr.options = {
        closeButton: true,
        progressBar: true,
        positionClass: "toast-top-right",
        timeOut: "1000"
    };
</script>
}

